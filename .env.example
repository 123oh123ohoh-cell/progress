# MongoDB Configuration for persistent data storage
# ===================================================

# MongoDB Atlas connection URI (required)
# Get this from: https://www.mongodb.com/cloud/atlas (free tier available)
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/?retryWrites=true&w=majority

# Database name (optional, defaults to "progress")
MONGODB_DB=progress

# Server port (optional, defaults to 3000)
PORT=3000


# Spotify Configuration (optional - powers "Connect Spotify" / currently-playing on profiles)
# ===================================================

# Create a free app at https://developer.spotify.com/dashboard (choose "Web API" only,
# not Web Playback SDK/iOS/Android) and add BOTH of these as Redirect URIs on it:
#   http://127.0.0.1:3000/api/spotify/callback
#   https://<your-render-app>.onrender.com/api/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Must exactly match one of the Redirect URIs registered on the Spotify app above.
# The local default below works out of the box; set this to the Render URL in production.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback


# SETUP INSTRUCTIONS
# ==================
# 1. Create a free MongoDB Atlas account at https://www.mongodb.com/cloud/atlas
#    - No credit card required for 3 months free tier
#    - Gives you 512MB free storage (enough for a blog with hundreds of posts/replies)
#
# 2. Create a new cluster in MongoDB Atlas
#    - Choose "Free" tier
#    - Select your preferred region
#
# 3. Create a database user
#    - Go to Database Access > Add New Database User
#    - Set a strong password
#    - Assign roles: readWriteAnyDatabase
#
# 4. Get your connection string
#    - Go to Clusters > Connect > Connect your application
#    - Copy the "Node.js" connection string
#    - Replace <username> and <password> with your database user credentials
#
# 5. Local development setup
#    - Copy this file: cp .env.example .env
#    - Edit .env with your MongoDB connection string
#    - Never commit .env to git (it's in .gitignore)
#    - Run: npm install && npm start
#
# 6. Production deployment (Render.com)
#    - Do NOT use .env in production
#    - In Render dashboard, set environment variables in your service settings:
#      * Add MONGODB_URI with your connection string
#      * Add MONGODB_DB with the database name
#    - Render will use these variables at runtime
#    - Make sure MongoDB Atlas allows connections from Render's IP range:
#      * Go to Atlas > Network Access > IP Whitelist
#      * Add: 0.0.0.0/0 (allows all IPs) OR add Render's specific IPs
#
# 7. Data persistence guarantees
#    - All data is stored in MongoDB (not on Render's ephemeral filesystem)
#    - Posts, replies, user profiles are safe even after server restarts
#    - Backups available through MongoDB Atlas dashboard
